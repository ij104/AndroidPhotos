<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/searchMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/searchTitleTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Search Photos"
        android:textSize="26sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <Button
        android:id="@+id/backToAlbumsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Back to albums" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="First tag"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/firstTagTypeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <RadioButton
            android:id="@+id/firstPersonRadio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Person" />

        <RadioButton
            android:id="@+id/firstLocationRadio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Location" />
    </RadioGroup>

    <AutoCompleteTextView
        android:id="@+id/firstValueEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="First tag value"
        android:completionThreshold="1"
        android:inputType="textCapWords" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="If you add a second value below"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="13sp" />

    <RadioGroup
        android:id="@+id/operatorGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <RadioButton
            android:id="@+id/operatorAndRadio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Match both (AND)" />

        <RadioButton
            android:id="@+id/operatorOrRadio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Match either (OR)" />
    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Second tag (optional)"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/secondTagTypeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <RadioButton
            android:id="@+id/secondPersonRadio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Person" />

        <RadioButton
            android:id="@+id/secondLocationRadio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Location" />
    </RadioGroup>

    <AutoCompleteTextView
        android:id="@+id/secondValueEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Second tag value optional"
        android:completionThreshold="1"
        android:inputType="textCapWords" />

    <Button
        android:id="@+id/runSearchButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Search" />

    <TextView
        android:id="@+id/resultsLabelTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Results"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingTop="12dp"
        android:paddingBottom="6dp" />

    <GridView
        android:id="@+id/searchResultsGridView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="3"
        android:verticalSpacing="8dp"
        android:horizontalSpacing="8dp"
        android:stretchMode="columnWidth"
        android:gravity="center" />

</LinearLayout>
